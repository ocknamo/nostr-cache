{
  "name": "@nostr-cache/web-client",
  "version": "0.1.0",
  "description": "Svelte web client for the nostr-cache local relay (timeline + NIP-01 filter form)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write ./src && biome check --write ./src",
    "format:check": "biome check ./src",
    "lint": "biome check ./src && npm run lint:svelte",
    "lint:check": "biome check ./src && npm run lint:svelte",
    "lint:fix": "biome check --write ./src && npm run lint:svelte -- --fix",
    "lint:svelte": "eslint \"src/**/*.svelte\"",
    "fix": "npm run lint:fix && npm run format",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@nostr-cache/cache-relay": "^0.1.0",
    "@nostr-cache/shared": "^0.1.0",
    "rx-nostr-crypto": "^3.1.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.20.0",
    "fake-indexeddb": "^6.0.0",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "svelte-eslint-parser": "^1.8.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.0",
    "vitest": "3.0.9"
  }
}
