{
  "name": "@nostr-cache/cache-relay",
  "version": "0.1.0",
  "description": "Cache relay for Nostr relay interactions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "node -e \"for(const p of ['dist','tsconfig.tsbuildinfo'])fs.rmSync(p,{recursive:true,force:true})\" && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write ./src && biome check --write ./src",
    "format:check": "biome check ./src",
    "lint": "biome check ./src",
    "lint:check": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "fix": "npm run lint:fix && npm run format",
    "fix:unsafe": "biome check --fix --unsafe",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@nostr-cache/shared": "^0.1.0",
    "dexie": "^4.0.11",
    "fake-indexeddb": "^6.0.0",
    "rx-nostr-crypto": "^3.1.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.5",
    "@vitest/coverage-v8": "3.0.9",
    "typescript": "^6.0.0",
    "vitest": "3.0.9"
  }
}
